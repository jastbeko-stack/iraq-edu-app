rules_version = '2';

// Security rules for the Iraq Edu App.
//
// Hard rules:
// - Coupons are read-only from the client; only Cloud Functions (which
//   run with admin privileges) may mark them used. This is what
//   prevents a malicious client from flipping `used` back to false.
// - Entitlements are readable only by the owning user, and only
//   writable by Cloud Functions.
// - Courses and study guides are public-read (catalog). Lessons are
//   public-read for metadata, but the playable video URL is gated by
//   the `getSignedLessonUrl` callable.
service cloud.firestore {
  match /databases/{database}/documents {

    match /coupons/{code} {
      allow read: if request.auth != null;
      allow write: if false; // Cloud Functions only.
    }

    match /entitlements/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false; // Cloud Functions only.
    }

    match /courses/{courseId} {
      allow read: if true;
      allow write: if false;

      match /lessons/{lessonId} {
        allow read: if true;
        allow write: if false;
      }
    }

    match /study_guides/{guideId} {
      allow read: if true;
      allow write: if false;
    }

    match /teachers/{teacherId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
